id: FR3_FR31Chan
label: FR31Chan(Not functioning)
category: '[FR3]'

templates:
  imports: from gnuradio import FR3
  make: FR3.FR31Chan()

templates:
  imports: from gnuradio import FR3
  make: FR3.FR31Chan(${freqRF}, ${freqIF}, ${RXgain}, ${TXgain})
  callbacks:
  - set_RFfreq(${RXfreq})
  - set_IFfreq(${IFfreq})
  - set_RXgain(${RXgain})
  - set_TXgain(${TXgain})
  
- id: freq
  label: RF Frequency
  dtype: float
  default: 10000000000.0
  setter: set_RFfreq  

- id: freq2
  label: IF Frequency
  dtype: float
  default: 1600000000.0
  setter: set_IFfreq  

- id: gain1
  label: RX Gain 
  dtype: float
  default: 30.0
  setter: set_RXgain 
- id: gain2
  label: TX Gain 
  dtype: float
  default: 30.0
  setter: set_TXgain  

  
inputs: 
  - domain: message
    type: float
    id: RF_freq
    optional: true
  - domain: message
    type: float
    id: IF_freq
    optional: true
  - domain: message
    type: float
    id: RX1_gain
    optional: true
  - domain: message
    type: float
    id: TX1_gain
    optional: true

    
file_format: 1